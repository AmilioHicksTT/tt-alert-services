PORT=3000
NODE_ENV=development

# ─── Supabase (PostgreSQL) ───────────────────────────────────────────────────
# supabase.com → your project → Settings → Database → Transaction pooler URI
DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# supabase.com → your project → Settings → API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# console.upstash.com → your database → Details → copy the rediss:// URL
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=30d

# ─── Twilio (SMS OTP) ─────────────────────────────────────────────────────────
# console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+18686xxxxxx

# ─── Firebase Admin (push notifications) ──────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=tt-alert-services
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tt-alert-services.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Scraper schedule ─────────────────────────────────────────────────────────
SCRAPER_INTERVAL=*/15 * * * *
